{
  "rewrites": [
    { "source": "/tour/:id",   "destination": "/tour.html" },
    { "source": "/dashboard",  "destination": "/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/tour.html",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        }
      ]
    }
  ]
}
